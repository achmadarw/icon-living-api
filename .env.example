# Server
NODE_ENV=development
PORT=4000

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/tia_dev

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=change-me-to-a-random-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-to-another-random-secret-at-least-32-chars

# CORS
CORS_ORIGINS=http://localhost:3000
