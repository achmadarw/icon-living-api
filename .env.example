# Server
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/tia_dev

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=change-me-to-a-random-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-to-another-random-secret-at-least-32-chars

# CORS
CORS_ORIGINS=http://localhost:3000

# Firebase Admin SDK (FCM Push Notification) - OPTIONAL
# If not configured, push notifications are silently disabled
# Get these from Firebase Console → Project Settings → Service Account
# Note: FIREBASE_PRIVATE_KEY should include the full PEM content with literal \n characters
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQE...\n-----END PRIVATE KEY-----\n"
